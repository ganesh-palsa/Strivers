class Solution {
    public boolean check(int[] nums) {
        int n=nums.length;
        if(n==1)
            return true;
        int c=1;
       for(int i=0;i<2*n;i++){
        if(nums[i%n]<=nums[(i+1)%n]){
            c++;
        }
        else{
            c=1;
        }
        if(c==n){
            return true;
        }
       }
       return false;
    }
}
