class Solution {
    void reverse(int[] arr,int i,int j){
        for(int k=i;k<j;k++){
            int temp=arr[k];
            arr[k]=arr[j];
            arr[j]=temp;
            j--;
        }
    }
    public void rotate(int[] arr) {
        // code here
        int i=0;
        int j=arr.length-1;
        reverse(arr,i,j-1);
        reverse(arr,j,j);
        reverse(arr,i,j);
    }
}
